<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Result</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{background:#0f172a;color:white;text-align:center;}
.info-box{background:#1f2937;padding:20px;border-radius:10px;margin-top:20px;}
</style>
</head>

<body>

    <!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark px-4" style="background:#111827;">
    <a class="navbar-brand" href="/">♻️ Garbage AI</a>

    <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm mx-1">Home</a>
        <a href="/predict" class="btn btn-outline-light btn-sm mx-1">Predict</a>
        <a href="/dashboard" class="btn btn-outline-light btn-sm mx-1">Dashboard</a>
        <a href="/analytics" class="btn btn-outline-light btn-sm mx-1">Analytics</a>
    </div>
</nav>

<div class="container mt-5">

<h2>🧠 Detection Result</h2>

<div class="info-box">
<p>
AI successfully analyzed the image and classified garbage type.
</p>
</div>

<h3 class="text-success mt-3"><%= result.label %></h3>

<img src="http://localhost:5000/<%= result.file_path %>" width="300" class="mt-3 rounded">

<br>

<a href="/predict" class="btn btn-primary mt-4">Try Again</a>
<a href="/dashboard" class="btn btn-info mt-4">View Dashboard</a>

</div>

<footer class="text-center p-3 mt-5">
Developed by Shrinath Rajput 🚀
</footer>

</body>
</html>