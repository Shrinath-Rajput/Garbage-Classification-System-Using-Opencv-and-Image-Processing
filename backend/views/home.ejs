<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Garbage AI</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a, #020617);
            color: white;
            font-family: 'Segoe UI', sans-serif;
        }

        .navbar {
            background: #111827;
        }

        .hero {
            text-align: center;
            padding: 120px 20px;
        }

        .btn-main {
            background: #16a34a;
            color: white;
            border: none;
            padding: 12px 25px;
            font-size: 18px;
            border-radius: 10px;
        }

        .btn-main:hover {
            background: #15803d;
        }

        .section {
            padding: 80px 20px;
            text-align: center;
        }

        .card-custom {
            background: #1f2937;
            border: none;
            border-radius: 15px;
            padding: 30px;
            color: white;
            transition: 0.3s;
        }

        .card-custom:hover {
            transform: translateY(-8px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.4);
        }

        .footer {
            background: #111827;
            text-align: center;
            padding: 20px;
            margin-top: 50px;
        }

        .icon {
            font-size: 40px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark px-4">
    <a class="navbar-brand" href="/">♻️ Garbage AI</a>

    <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm mx-1">Home</a>
        <a href="/predict" class="btn btn-outline-light btn-sm mx-1">Predict</a>
        <a href="/dashboard" class="btn btn-outline-light btn-sm mx-1">Dashboard</a>
        <a href="/analytics" class="btn btn-outline-light btn-sm mx-1">Analytics</a>
    </div>
</nav>

<!-- Hero Section -->
<div class="hero">
    <h1 class="fw-bold">♻️ Smart Garbage Detection System</h1>
    <p class="text-muted mt-3">
        AI-based system to classify garbage like plastic, metal, paper, etc.
    </p>

    <a href="/predict" class="btn btn-main mt-3">🚀 Start Detection</a>
</div>

<!-- Features -->
<div class="section">
    <h2 class="mb-5">✨ Features</h2>

    <div class="container">
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card-custom">
                    <div class="icon">📸</div>
                    <h5>Live Capture</h5>
                    <p>Capture garbage using camera or upload image.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-custom">
                    <div class="icon">🧠</div>
                    <h5>AI Detection</h5>
                    <p>Detect garbage type using AI model instantly.</p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card-custom">
                    <div class="icon">🗄️</div>
                    <h5>Storage</h5>
                    <p>Store prediction history in MySQL database.</p>
                </div>
            </div>

        </div>
    </div>
</div>

<!-- How it Works -->
<div class="section">
    <h2>⚙️ How it Works</h2>
    <p class="mt-3">
        Capture Image → AI Prediction → Save → View in Dashboard
    </p>
</div>

<!-- About -->
<div class="section">
    <h2>📌 About Project</h2>
    <p class="mt-3 container">
        This project is built using Node.js, Express, MySQL, and Python AI service.
        It helps classify waste and supports smart waste management systems.
    </p>
</div>

<!-- Footer -->
<div class="footer">
    Developed by <b>Shrinath Rajput 🚀</b>
</div>

</body>
</html>