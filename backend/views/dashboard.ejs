<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{background:#0f172a;color:white;}
.section{padding:40px;}
.info{background:#1f2937;padding:15px;border-radius:10px;margin-bottom:20px;}
</style>
</head>

<body>
    <!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark px-4" style="background:#111827;">
    <a class="navbar-brand" href="/">♻️ Garbage AI</a>

    <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm mx-1">Home</a>
        <a href="/predict" class="btn btn-outline-light btn-sm mx-1">Predict</a>
        <a href="/dashboard" class="btn btn-outline-light btn-sm mx-1">Dashboard</a>
        <a href="/analytics" class="btn btn-outline-light btn-sm mx-1">Analytics</a>
    </div>
</nav>

<div class="container section">

<h1>📊 Dashboard</h1>

<div class="info">
<p>
This dashboard shows all detected garbage records stored in database.
You can monitor, delete or clear history.
</p>
</div>

<a href="/predict" class="btn btn-success">➕ New Detection</a>
<a href="/clear" class="btn btn-warning"
onclick="return confirm('Clear all records?')">⚠️ Clear All</a>

<table class="table table-dark table-bordered mt-3 text-center">

<thead>
<tr>
<th>ID</th>
<th>Image</th>
<th>Label</th>
<th>Time</th>
<th>Action</th>
</tr>
</thead>

<tbody>
<% data.forEach(item => { %>
<tr>
<td><%= item.id %></td>
<td><img src="http://localhost:5000/<%= item.file_path %>" width="80"></td>
<td><%= item.label %></td>
<td><%= item.timestamp %></td>
<td>
<a href="/delete/<%= item.id %>" class="btn btn-danger btn-sm">Delete</a>
</td>
</tr>
<% }) %>
</tbody>

</table>

<a href="/" class="btn btn-secondary mt-4">⬅ Back</a>

</div>

<!-- EXTRA SCROLL CONTENT -->
<div class="container section">
<h3>📌 Insights</h3>
<p>
Dashboard helps track garbage trends and improve waste management decisions.
</p>
</div>

<div class="container section">
<h3>🚀 Future Improvements</h3>
<p>
Real AI model integration, smart bin recommendation, and mobile app integration.
</p>
</div>

<footer class="text-center p-3">
Developed by Shrinath Rajput 🚀
</footer>

</body>
</html>