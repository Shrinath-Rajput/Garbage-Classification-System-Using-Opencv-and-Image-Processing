<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Analytics</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body{background:#0f172a;color:white;}
.section{padding:50px;text-align:center;}
.info{background:#1f2937;padding:20px;border-radius:10px;margin-bottom:20px;}
</style>
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark px-4" style="background:#111827;">
    <a class="navbar-brand" href="/">♻️ Garbage AI</a>

    <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm mx-1">Home</a>
        <a href="/predict" class="btn btn-outline-light btn-sm mx-1">Predict</a>
        <a href="/dashboard" class="btn btn-outline-light btn-sm mx-1">Dashboard</a>
        <a href="/analytics" class="btn btn-outline-light btn-sm mx-1">Analytics</a>
    </div>
</nav>

<div class="container section">

<h1>📈 Garbage Analytics</h1>

<div class="info">
<p>Chart shows garbage distribution.</p>
</div>

<canvas id="chart"></canvas>

<a href="/" class="btn btn-secondary mt-4">⬅ Back</a>

</div>

<footer class="text-center p-3">
Developed by Shrinath Rajput 🚀
</footer>

<script>
const labels = <%- JSON.stringify(labels || []) %>;
const counts = <%- JSON.stringify(counts || []) %>;

new Chart(document.getElementById("chart"), {
type:"bar",
data:{
labels:labels,
datasets:[{label:"Garbage Count",data:counts}]
}
});
</script>

</body>
</html>