<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Predict</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body{background:#0f172a;color:white;}
.section{padding:50px 0;text-align:center;}
.info{background:#1f2937;padding:20px;border-radius:10px;margin:20px 0;}
video{border-radius:10px;}
</style>
</head>

<body>

    <!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-dark px-4" style="background:#111827;">
    <a class="navbar-brand" href="/">♻️ Garbage AI</a>

    <div class="ms-auto">
        <a href="/" class="btn btn-outline-light btn-sm mx-1">Home</a>
        <a href="/predict" class="btn btn-outline-light btn-sm mx-1">Predict</a>
        <a href="/dashboard" class="btn btn-outline-light btn-sm mx-1">Dashboard</a>
        <a href="/analytics" class="btn btn-outline-light btn-sm mx-1">Analytics</a>
    </div>
</nav>

<div class="container section">

<h1>📸 Garbage Detection System</h1>

<p class="text-muted">
Use AI to detect garbage types efficiently
</p>

<div class="info">
<h5>How to Use</h5>
<p>
1️⃣ Capture image using camera<br>
2️⃣ OR upload an image<br>
3️⃣ Click detect<br>
4️⃣ View result instantly
</p>
</div>

<!-- CAMERA -->
<video id="video" width="320" autoplay></video><br><br>
<button class="btn btn-success" onclick="capture()">📸 Capture & Detect</button>

<!-- UPLOAD -->
<form action="/predict" method="POST" enctype="multipart/form-data" class="mt-4">
<input type="file" name="image" class="form-control">
<button class="btn btn-primary mt-2 w-100">Upload & Detect</button>
</form>

<canvas id="canvas" width="320" style="display:none;"></canvas>

<form id="form" method="POST" action="/predict">
<input type="hidden" name="imageData" id="imageData">
</form>

<a href="/" class="btn btn-secondary mt-4">⬅ Back</a>

</div>

<!-- EXTRA CONTENT FOR SCROLL -->
<div class="container section">
<h3>📌 Why this system?</h3>
<p>
This system helps in smart waste management by identifying garbage type automatically.
It reduces human effort and improves recycling efficiency.
</p>
</div>

<div class="container section">
<h3>✨ Features</h3>
<p>
✔ Live camera detection<br>
✔ AI prediction<br>
✔ Data stored in database<br>
✔ Dashboard visualization
</p>
</div>

<footer class="text-center p-3">
Developed by Shrinath Rajput 🚀
</footer>

<script>
const video = document.getElementById("video");
navigator.mediaDevices.getUserMedia({video:true})
.then(stream => video.srcObject = stream);

function capture(){
const canvas=document.getElementById("canvas");
const ctx=canvas.getContext("2d");
ctx.drawImage(video,0,0,canvas.width,canvas.height);
document.getElementById("imageData").value=canvas.toDataURL("image/jpeg");
document.getElementById("form").submit();
}
</script>

</body>
</html>